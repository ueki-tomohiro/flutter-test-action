{
  "compilerOptions": {
    "target": "es2022",                       /* Specify ECMAScript target version. */
    "lib": ["es2022"],                        /* Use modern built-in types required by current dependencies. */
    "module": "node16",                       /* Emit CommonJS while preserving native import() for ESM-only packages. */
    "moduleResolution": "node16",             /* Resolve package exports used by modern @actions/* packages. */
    "outDir": "./lib",                        /* Redirect output structure to the directory. */
    "rootDir": "./src",                       /* Specify the root directory of input files. Use to control the output directory structure with --outDir. */
    "strict": true,                           /* Enable all strict type-checking options. */
    "noImplicitAny": true,                    /* Raise error on expressions and declarations with an implied 'any' type. */
    "isolatedModules": true,                  /* Keeps test transpilation compatible with modern module semantics. */
    "esModuleInterop": true,                  /* Enables emit interoperability between CommonJS and ES Modules via creation of namespace objects for all imports. Implies 'allowSyntheticDefaultImports'. */
  },
  "exclude": ["node_modules", "**/*.test.ts"]
}
